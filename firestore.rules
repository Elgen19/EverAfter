rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Helper function to check if the email is a bootstrap admin (cryptographically signed by Auth token)
    function isBootstrapAdmin() {
      return request.auth != null && 
        request.auth.token.email in [
          'admin@everafterletters.xyz',
          'elgen@example.com',
          'your-email@example.com' // Add your custom admin email here
        ];
    }
    
    // 1. User Profiles
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      
      // Allow profile creation. Only allow setting role='admin' if the email is in the bootstrap list.
      allow create: if request.auth != null && request.auth.uid == userId && (
        (request.resource.data.role == 'user' && request.resource.data.isAdmin == false) ||
        (request.resource.data.role == 'admin' && request.resource.data.isAdmin == true && isBootstrapAdmin())
      );
      
      // Allow updates. Regular users cannot touch the 'role' or 'isAdmin' fields when modifying their profiles.
      allow update: if (
        request.auth != null && request.auth.uid == userId && (
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin'])) ||
          isBootstrapAdmin()
        )
      ) || isAdmin();
      
      // Only admins can delete profiles
      allow delete: if isAdmin();
    }
    
    // 2. Letters Collection
    match /letters/{letterId} {
      allow get: if true;
      allow list: if request.auth != null || isAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isAdmin();
      
      allow update: if 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'read', 
          'readAt', 
          'survey', 
          'dateInvitation', 
          'quiz'
        ]))
        || 
        (request.auth != null && resource.data.userId == request.auth.uid)
        ||
        isAdmin();
    }
    
    // 3. Contacts Collection
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 4. Performance Metrics (Telemetry logs)
    match /performance_metrics/{metricId} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // 5. System Configuration (Maintenance mode, etc.)
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
